# Copy this file to .env and fill in your values.
# DO NOT commit .env to git.

# YouTube channel to monitor
YOUTUBE_CHANNEL_ID=UCAjbXXOyV673M85ei4Phf-g

# The public URL of your deployed backend (no trailing slash)
